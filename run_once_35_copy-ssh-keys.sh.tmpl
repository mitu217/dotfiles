{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -eu

echo "==> Copying SSH keys from 1Password..."

SSH_DIR="$HOME/.ssh"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

copy_key() {
    local item="$1"
    local private_path="$2"
    local public_path="$3"

    if [ -f "$private_path" ]; then
        echo "Already exists, skipping: $private_path"
        return
    fi

    echo "Fetching: $item"
    op item get "$item" --vault personal --fields private_key --reveal | tr -d '"' > "$private_path"
    chmod 600 "$private_path"

    op item get "$item" --vault personal --fields public_key | tr -d '"' > "$public_path"
    chmod 644 "$public_path"

    echo "Saved: $private_path"
}

copy_key "Github(1Password/personal)"         "$SSH_DIR/id_ed25519"         "$SSH_DIR/id_ed25519.pub"
copy_key "GitHub(1Password/personal/signing)" "$SSH_DIR/id_ed25519_signing" "$SSH_DIR/id_ed25519_signing.pub"

echo "SSH key copy complete"
{{- end }}
